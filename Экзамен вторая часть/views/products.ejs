<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/assets/styles.css">
</head>
<body>
  <header class="topbar">
    <div>
      <p class="eyebrow">Главная</p>
      <h1>Список тортов</h1>
    </div>
    <div class="user">
      <strong><%= user.full_name %></strong>
      <span><%= user.role_name %></span>
    </div>
  </header>

  <main class="content">
    <section class="table-panel">
      <table>
        <thead>
          <tr>
            <th>Артикул</th>
            <th>Название</th>
            <th>Тип</th>
            <th>Кондитерская</th>
            <th>Цена</th>
            <th>Скидка</th>
            <th>Остаток</th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach((product) => { %>
            <tr>
              <td><%= product.article %></td>
              <td><strong><%= product.name %></strong></td>
              <td><%= product.cake_type_name %></td>
              <td><%= product.confectionery_name %></td>
              <td><%= Number(product.price).toLocaleString('ru-RU', { minimumFractionDigits: 2 }) %> ₽</td>
              <td><%= product.discount_percent %>%</td>
              <td><%= product.stock_quantity %> <%= product.unit_name %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </main>
</body>
</html>
